---
const {
  title = "Tampa Bay Club Sport — Team Cards",
  description = "Shareable rec-league team cards.",
  image,            // absolute URL to the social preview image
  canonical,        // absolute canonical URL
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {image && <meta property="og:image" content={image} />}
    {image && <meta property="og:image:width" content="1200" />}
    {image && <meta property="og:image:height" content="630" />}

    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100dvh;
        font-family: "Inter", system-ui, -apple-system, sans-serif;
        color: #EAF1FF;
        background:
          radial-gradient(90% 60% at 50% -10%, #15315E 0%, transparent 60%),
          linear-gradient(180deg, #0A1730 0%, #070F22 100%);
        background-attachment: fixed;
      }
      a { color: inherit; text-decoration: none; }
    </style>
  </body>
</html>
