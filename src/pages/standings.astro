---
import Base from "../layouts/Base.astro";
import { getStandings } from "../lib/stats.js";

const groups = await getStandings();
const season = groups[0]?.teams[0]?.season || "";

const ACCENT = { c: "#FFC247", r: "#38D6C4", ia: "#FF7A4D", ib: "#9B8CFF", ic: "#5AA9FF" };
---
<Base title="Tampa Bay Club Sport — Standings">
  <main class="wrap">
    <a class="back" href="/">← Team Cards</a>
    <header class="head">
      <p class="eyebrow">Tampa Bay Club Sport · {season}</p>
      <h1>Standings</h1>
      <p class="sub">Monday Coed Volleyball — every team's record, win rate, and form. Tap a team for its card.</p>
    </header>

    {groups.map((g) => (
      <section class="division">
        <h2 style={`--accent:${ACCENT[g.divisionCode] || "#FFC247"}`}>{g.division}</h2>
        <ol class="rows">
          {g.teams.map((t, i) => (
            <li>
              <a href={`/team/${t.teamId}`} class="row">
                <span class="rank">{i + 1}</span>
                <span class="name">{t.name}</span>
                <span class="rec">{t.wins}-{t.losses}</span>
                <span class="pct" style={`--accent:${ACCENT[g.divisionCode] || "#FFC247"}`}>
                  {Math.round(t.winRate * 100)}%
                </span>
                <span class="form">
                  {t.recentForm.map((r) => (
                    <i class={r === "W" ? "w" : "l"} style={`--accent:${ACCENT[g.divisionCode] || "#FFC247"}`}></i>
                  ))}
                </span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </main>

  <style>
    .wrap { max-width: 720px; margin: 0 auto; padding: 40px 20px 80px; }
    .back { display: inline-block; font-size: 13px; color: #9DB2D8; padding: 8px 4px; margin-bottom: 8px; }
    .back:hover { color: #EAF1FF; }
    .eyebrow { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: #9DB2D8; font-weight: 700; margin: 0; }
    h1 { font-size: 40px; margin: 6px 0 8px; letter-spacing: -.02em; }
    .sub { color: #9DB2D8; margin: 0 0 8px; max-width: 46ch; }
    .division { margin-top: 36px; }
    .division h2 { font-size: 13px; letter-spacing: .16em; text-transform: uppercase; color: var(--accent); margin: 0 0 10px; }
    .rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .row {
      display: grid; grid-template-columns: 24px 1fr auto 52px auto; align-items: center; gap: 12px;
      padding: 12px 14px; border-radius: 12px;
      background: #ffffff08; box-shadow: inset 0 0 0 1px #ffffff12;
      transition: background .15s ease, transform .15s ease;
    }
    .row:hover { background: #ffffff12; transform: translateX(2px); }
    .rank { color: #67799E; font-size: 13px; font-variant-numeric: tabular-nums; }
    .name { font-weight: 600; }
    .rec { color: #C9D6F0; font-variant-numeric: tabular-nums; font-size: 14px; }
    .pct { color: var(--accent); font-weight: 800; text-align: right; font-variant-numeric: tabular-nums; }
    .form { display: inline-flex; gap: 4px; }
    .form i { width: 9px; height: 9px; border-radius: 50%; }
    .form i.w { background: var(--accent); }
    .form i.l { box-shadow: inset 0 0 0 1.5px #ffffff2e; }
    @media (max-width: 520px) {
      h1 { font-size: 30px; }
      .row { grid-template-columns: 22px 1fr auto 46px; }
      .form { display: none; }
    }
  </style>
</Base>
